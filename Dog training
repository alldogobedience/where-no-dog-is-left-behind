<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Good Dog Trainer | Client Portal</title>
    <style>
        :root { --primary: #ff9f43; --secondary: #54a0ff; --bg: #f8f9fa; --text: #2d3436; --success: #55efc4; }
        body { font-family: 'Segoe UI', Tahoma, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 20px; padding-bottom: 60px; }
        h1 { text-align: center; color: var(--primary); margin-bottom: 5px; }
        .card { background: white; border-radius: 15px; padding: 15px; margin-bottom: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border-bottom: 4px solid var(--secondary); }
        h2 { font-size: 1.1rem; margin-top: 0; color: #636e72; display: flex; align-items: center; gap: 8px; }
        input, textarea, button { width: 100%; padding: 12px; margin: 8px 0; border-radius: 10px; border: 1px solid #ddd; box-sizing: border-box; font-family: inherit; }
        button { background: var(--primary); color: white; border: none; font-weight: bold; cursor: pointer; transition: 0.2s; }
        button:active { transform: scale(0.98); }
        .hidden { display: none !important; }
        
        /* Profile */
        .profile-section { text-align: center; margin-bottom: 20px; }
        #photoDisplay { width: 100px; height: 100px; border-radius: 50%; border: 3px solid white; box-shadow: 0 4px 8px rgba(0,0,0,0.1); object-fit: cover; background: #ddd; margin: 0 auto 10px; display: block; }
        .file-label { background: var(--secondary); color: white; padding: 6px 12px; border-radius: 20px; cursor: pointer; font-size: 0.75rem; }
        
        /* List Items */
        .item { background: #f1f2f6; padding: 10px; border-radius: 8px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; }
        .del { width: auto; background: #ff7675; padding: 4px 8px; margin: 0; font-size: 0.7rem; }
        .journal-entry { border-left: 4px solid var(--primary); padding: 10px; margin-bottom: 10px; background: #fff; border-radius: 5px; }
    </style>
</head>
<body>

    <h1>🐾 Good Dog Trainer</h1>

    <div id="publicArea">
        <div class="card">
            <h2>Welcome!</h2>
            <p>I help dogs and their humans thrive. Use the form below to ask a question, or log in to your private portal.</p>
        </div>

        <div class="card">
            <h2>🙋 Ask a Training Question</h2>
            <input type="email" placeholder="Your Email">
            <textarea placeholder="Describe your dog's behavior..."></textarea>
            <button onclick="alert('Message Sent!')" style="background: var(--secondary);">Send to Trainer</button>
        </div>

        <div class="card" id="loginBox">
            <h2>🔒 Client Portal</h2>
            <input type="password" id="passInput" placeholder="Enter Master Password">
            <button onclick="checkPass()">View Private Progress</button>
        </div>
    </div>

    <div id="privateArea" class="hidden">
        <button onclick="logout()" style="background:#b2bec3; width: auto; float: right; margin-bottom: 10px;">Logout</button>
        
        <div class="profile-section">
            <img id="photoDisplay" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23999'%3E%3Cpath d='M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z'/%3E%3C/svg%3E">
            <label class="file-label">📸 Change Photo <input type="file" id="photoInput" accept="image/*" style="display:none"></label>
        </div>

        <div class="card">
            <h2>📅 Appointments</h2>
            <input type="text" id="apptDesc" placeholder="Class/Session Name">
            <input type="date" id="apptDate">
            <button onclick="addAppt()">Save Appointment</button>
            <div id="apptList"></div>
        </div>

        <div class="card">
            <h2>🎾 Training Skills</h2>
            <div style="display:flex; gap:5px;">
                <input type="text" id="newSkill" placeholder="Add a new skill..." style="margin:0;">
                <button onclick="addSkill()" style="width:80px; margin:0; background:var(--secondary);">Add</button>
            </div>
            <div id="skillList" style="margin-top:15px;"></div>
        </div>

        <div class="card">
            <h2>📖 Training Journal</h2>
            <textarea id="journalText" placeholder="How did practice go today?"></textarea>
            <button onclick="addJournal()" style="background:var(--secondary);">Save Note</button>
            <div id="journalList" style="margin-top:15px;"></div>
        </div>
    </div>

    <script>
        const MASTER_PASS = "Puppy2026"; // Change this whenever you want!

        window.onload = () => {
            if(sessionStorage.getItem('isLogged')) showPrivate();
        };

        function checkPass() {
            if(document.getElementById('passInput').value === MASTER_PASS) {
                sessionStorage.setItem('isLogged', 'true');
                showPrivate();
            } else { alert("Wrong password!"); }
        }

        function showPrivate() {
            document.getElementById('publicArea').classList.add('hidden');
            document.getElementById('privateArea').classList.remove('hidden');
            loadData();
        }

        function logout() {
            sessionStorage.removeItem('isLogged');
            location.reload();
        }

        // --- DATA LOGIC ---
        function addAppt() {
            const desc = document.getElementById('apptDesc').value;
            const date = document.getElementById('apptDate').value;
            if(!desc || !date) return;
            saveItem('appts', {desc, date, id: Date.now()});
            document.getElementById('apptDesc').value = '';
            renderAppts();
        }

        function addSkill() {
            const name = document.getElementById('newSkill').value;
            if(!name) return;
            saveItem('skills', {name, done: false, id: Date.now()});
            document.getElementById('newSkill').value = '';
            renderSkills();
        }

        function addJournal() {
            const text = document.getElementById('journalText').value;
            if(!text) return;
            saveItem('journal', {text, date: new Date().toLocaleDateString(), id: Date.now()}, true);
            document.getElementById('journalText').value = '';
            renderJournal();
        }

        // Helpers
        function saveItem(key, obj, unshift=false) {
            let data = JSON.parse(localStorage.getItem(key)) || [];
            unshift ? data.unshift(obj) : data.push(obj);
            localStorage.setItem(key, JSON.stringify(data));
        }

        function deleteItem(key, id, cb) {
            let data = JSON.parse(localStorage.getItem(key)).filter(i => i.id !== id);
            localStorage.setItem(key, JSON.stringify(data));
            cb();
        }

        function renderAppts() {
            const data = JSON.parse(localStorage.getItem('appts')) || [];
            document.getElementById('apptList').innerHTML = data.map(a => `
                <div class="item"><span><strong>${a.date}</strong>: ${a.desc}</span>
                <button class="del" onclick="deleteItem('appts', ${a.id}, renderAppts)">X</button></div>
            `).join('');
        }

        function renderSkills() {
            const data = JSON.parse(localStorage.getItem('skills')) || [];
            document.getElementById('skillList').innerHTML = data.map(s => `
                <div class="item"><span>${s.name}</span>
                <button class="del" onclick="deleteItem('skills', ${s.id}, renderSkills)">Remove</button></div>
            `).join('');
        }

        function renderJournal() {
            const data = JSON.parse(localStorage.getItem('journal')) || [];
            document.getElementById('journalList').innerHTML = data.map(j => `
                <div class="journal-entry"><strong>${j.date}</strong><p>${j.text}</p>
                <span style="color:red; cursor:pointer; font-size:0.7rem;" onclick="deleteItem('journal', ${j.id}, renderJournal)">Delete</span></div>
            `).join('');
        }

        function loadData() {
            renderAppts(); renderSkills(); renderJournal();
            const photo = localStorage.getItem('photo');
            if(photo) document.getElementById('photoDisplay').src = photo;
        }

        document.getElementById('photoInput').onchange = (e) => {
            const reader = new FileReader();
            reader.onload = () => {
                document.getElementById('photoDisplay').src = reader.result;
                localStorage.setItem('photo', reader.result);
            };
            reader.readAsDataURL(e.target.files[0]);
        };
    </script>
</body>
</html>
